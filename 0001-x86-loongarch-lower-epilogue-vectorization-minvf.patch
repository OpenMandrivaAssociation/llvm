From: LLVM Developer <dev@llvm.org>
Date: Tue, 22 Jul 2026 00:00:00 +0000
Subject: [PATCH 1/3] [X86][LoongArch][TTI] Lower epilogue vectorization MinVF
 threshold for SSE and LSX targets

On SSE-only x86 targets and LoongArch with LSX (128-bit vectors), the
default epilogue vectorization threshold of 16 prevented epilogue
vectorization for many loops. With VF=4 (float, 128-bit) and IC=2,
VF*IC=8 < 16, so the epilogue was always scalar.

This produced large scalar remainder loops that the unroller would
fully unroll, causing significant code bloat. For example, a 2D stencil
computation generated 72 instructions versus GCC's 41.

Lower the threshold to 8 for these targets, allowing epilogue
vectorization at VF=4 to process remainder elements with SIMD
instructions instead of scalar code. This reduces the stencil from
72 to 57 instructions.

The AArch64 target already has per-core overrides and RISC-V with RVV
uses scalable vectors that don't have this issue, so only X86 (SSE)
and LoongArch (LSX/LASX) are modified.

---
diff --git a/llvm/lib/Target/LoongArch/LoongArchTargetTransformInfo.cpp b/llvm/lib/Target/LoongArch/LoongArchTargetTransformInfo.cpp
index 9f63714db..2bff2fa19 100644
--- a/llvm/lib/Target/LoongArch/LoongArchTargetTransformInfo.cpp
+++ b/llvm/lib/Target/LoongArch/LoongArchTargetTransformInfo.cpp
@@ -135,3 +135,14 @@ LoongArchTTIImpl::enableMemCmpExpansion(bool OptSize, bool IsZeroCmp) const {
 
   return Options;
 }
+
+unsigned LoongArchTTIImpl::getEpilogueVectorizationMinVF() const {
+  // With LASX (256-bit vectors), allow epilogue vectorization at lower VFs.
+  if (ST->hasExtLASX())
+    return 8;
+  // With LSX (128-bit vectors), the main loop processes VF*IC elements.
+  // Allow epilogue vectorization to reduce scalar remainder code bloat.
+  if (ST->hasExtLSX())
+    return 8;
+  return BaseT::getEpilogueVectorizationMinVF();
+}
diff --git a/llvm/lib/Target/LoongArch/LoongArchTargetTransformInfo.h b/llvm/lib/Target/LoongArch/LoongArchTargetTransformInfo.h
index 2392b7097..3d7be978a 100644
--- a/llvm/lib/Target/LoongArch/LoongArchTargetTransformInfo.h
+++ b/llvm/lib/Target/LoongArch/LoongArchTargetTransformInfo.h
@@ -67,6 +67,8 @@ public:
       std::optional<FastMathFlags> FMF) const override {
     return InstructionCost::getInvalid();
   }
+
+  unsigned getEpilogueVectorizationMinVF() const override;
 };
 
 } // end namespace llvm
diff --git a/llvm/lib/Target/X86/X86TargetTransformInfo.cpp b/llvm/lib/Target/X86/X86TargetTransformInfo.cpp
index e80fd692d..76c95be0c 100644
--- a/llvm/lib/Target/X86/X86TargetTransformInfo.cpp
+++ b/llvm/lib/Target/X86/X86TargetTransformInfo.cpp
@@ -252,6 +252,23 @@ unsigned X86TTIImpl::getMaxInterleaveFactor(ElementCount VF,
   return 2;
 }
 
+unsigned X86TTIImpl::getEpilogueVectorizationMinVF() const {
+  // With AVX-512 (512-bit vectors), the default threshold of 16 is appropriate
+  // since the main loop already processes many elements per iteration.
+  if (ST->hasAVX512())
+    return 16;
+  // With AVX/AVX2 (256-bit vectors), an epilogue VF of 4 is still useful to
+  // avoid bloated scalar remainders.
+  if (ST->hasAVX())
+    return 8;
+  // With SSE only (128-bit vectors), the main loop often processes VF*IC = 8
+  // elements per iteration (VF=4, IC=2 for floats). Without epilogue
+  // vectorization, the scalar remainder can be up to 7 iterations, which the
+  // unroller fully unrolls into significant code bloat. Allowing epilogue
+  // vectorization at VF=4 eliminates most of this.
+  return 8;
+}
+
 InstructionCost X86TTIImpl::getArithmeticInstrCost(
     unsigned Opcode, Type *Ty, TTI::TargetCostKind CostKind,
     TTI::OperandValueInfo Op1Info, TTI::OperandValueInfo Op2Info,
diff --git a/llvm/lib/Target/X86/X86TargetTransformInfo.h b/llvm/lib/Target/X86/X86TargetTransformInfo.h
index 22171f546..4638de734 100644
--- a/llvm/lib/Target/X86/X86TargetTransformInfo.h
+++ b/llvm/lib/Target/X86/X86TargetTransformInfo.h
@@ -66,6 +66,7 @@ public:
   unsigned getLoadStoreVecRegBitWidth(unsigned AS) const override;
   unsigned getMaxInterleaveFactor(ElementCount VF,
                                   bool HasUnorderedReductions) const override;
+  unsigned getEpilogueVectorizationMinVF() const override;
   InstructionCost getArithmeticInstrCost(
       unsigned Opcode, Type *Ty, TTI::TargetCostKind CostKind,
       TTI::OperandValueInfo Op1Info = {TTI::OK_AnyValue, TTI::OP_None},
