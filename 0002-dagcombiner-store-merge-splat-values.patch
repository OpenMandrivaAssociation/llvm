+bool DAGCombiner::tryStoreMergeOfSplatValues(
+    SmallVectorImpl<MemOpLink> &StoreNodes, unsigned NumConsecutiveStores,
+    EVT MemVT, SDNode *RootNode, bool AllowVectors) {
+  // Merge consecutive stores of the same value into a single wider store.
+  // For example, two adjacent stores of the same pointer value can be merged
+  // into a single 128-bit store using a vector splat:
+  //   store p, [base]
+  //   store p, [base+8]
+  // becomes:
+  //   store <2 x p>, [base]   (using BUILD_VECTOR to splat p)
+  LLVMContext &Context = *DAG.getContext();
+  const DataLayout &DL = DAG.getDataLayout();
+  bool MadeChange = false;
+
+  while (NumConsecutiveStores >= 2) {
+    // All stores in the run must store the same value.
+    StoreSDNode *FirstStore = cast<StoreSDNode>(StoreNodes[0].MemNode);
+    SDValue SplatVal = peekThroughBitcasts(FirstStore->getValue());
+    unsigned NumStoresToMerge = 1;
+    for (unsigned i = 1; i < NumConsecutiveStores; ++i) {
+      StoreSDNode *OtherStore = cast<StoreSDNode>(StoreNodes[i].MemNode);
+      SDValue OtherVal = peekThroughBitcasts(OtherStore->getValue());
+      if (OtherVal != SplatVal)
+        break;
+      NumStoresToMerge = i + 1;
+    }
+
+    if (NumStoresToMerge < 2) {
+      StoreNodes.erase(StoreNodes.begin());
+      --NumConsecutiveStores;
+      continue;
+    }
+
+    // We must only use vectors if the target allows it.
+    if (!AllowVectors) {
+      StoreNodes.erase(StoreNodes.begin(),
+                       StoreNodes.begin() + NumStoresToMerge);
+      NumConsecutiveStores -= NumStoresToMerge;
+      continue;
+    }
+
+    // Find the largest legal vector type we can use for the merged store.
+    unsigned FirstStoreAS = FirstStore->getAddressSpace();
+    Align FirstStoreAlign = FirstStore->getAlign();
+    unsigned NumMemElts = MemVT.isVector() ? MemVT.getVectorNumElements() : 1;
+    unsigned BestNumStores = 0;
+
+    for (unsigned i = 2; i <= NumStoresToMerge; ++i) {
+      unsigned Elts = i * NumMemElts;
+      EVT VecTy = EVT::getVectorVT(Context, MemVT.getScalarType(), Elts);
+      unsigned IsFast = 0;
+      if (VecTy.getSizeInBits() > TLI.getMaximumLegalStoreInBits())
+        break;
+      if (TLI.isTypeLegal(VecTy) &&
+          TLI.canMergeStoresTo(FirstStoreAS, VecTy,
+                               DAG.getMachineFunction()) &&
+          TLI.allowsMemoryAccess(Context, DL, VecTy,
+                                 *FirstStore->getMemOperand(), &IsFast) &&
+          IsFast)
+        BestNumStores = i;
+    }
+
+    if (BestNumStores < 2) {
+      StoreNodes.erase(StoreNodes.begin(),
+                       StoreNodes.begin() + NumStoresToMerge);
+      NumConsecutiveStores -= NumStoresToMerge;
+      continue;
+    }
+
+    // Check for dependencies before merging.
+    if (!checkMergeStoreCandidatesForDependencies(StoreNodes, BestNumStores,
+                                                  RootNode)) {
+      StoreNodes.erase(StoreNodes.begin(),
+                       StoreNodes.begin() + BestNumStores);
+      NumConsecutiveStores -= BestNumStores;
+      continue;
+    }
+
+    // Build a vector splat of the stored value.
+    unsigned MergedElts = BestNumStores * NumMemElts;
+    EVT MergedVT =
+        EVT::getVectorVT(Context, MemVT.getScalarType(), MergedElts);
+    SDLoc StoreDL(StoreNodes[0].MemNode);
+
+    // Create the splat vector: broadcast the value into all lanes.
+    SDValue StoreValForVec = FirstStore->getValue();
+    if (MemVT != StoreValForVec.getValueType())
+      StoreValForVec = DAG.getBitcast(MemVT, StoreValForVec);
+
+    SmallVector<SDValue, 8> SplatOps(BestNumStores, StoreValForVec);
+    SDValue SplatVec =
+        DAG.getNode(MemVT.isVector() ? ISD::CONCAT_VECTORS
+                                     : ISD::BUILD_VECTOR,
+                    StoreDL, MergedVT, SplatOps);
+
+    // Collect AA metadata.
+    AAMDNodes AAInfo = FirstStore->getAAInfo();
+    for (unsigned i = 1; i < BestNumStores; ++i) {
+      StoreSDNode *OtherStore = cast<StoreSDNode>(StoreNodes[i].MemNode);
+      AAInfo = AAInfo.concat(OtherStore->getAAInfo());
+    }
+
+    // Build the merged store.
+    bool CanReusePtrInfo = hasSameUnderlyingObj(StoreNodes);
+    SDValue NewChain = getMergeStoreChains(StoreNodes, BestNumStores);
+    MachineMemOperand::Flags MMOFlags = FirstStore->getMemOperand()->getFlags();
+    SDValue NewStore = DAG.getStore(
+        NewChain, StoreDL, SplatVec, FirstStore->getBasePtr(),
+        CanReusePtrInfo
+            ? FirstStore->getPointerInfo()
+            : MachinePointerInfo(FirstStore->getPointerInfo().getAddrSpace()),
+        FirstStoreAlign, MMOFlags, AAInfo);
+
+    // Replace all merged stores with the new store.
+    for (unsigned i = 0; i < BestNumStores; ++i)
+      CombineTo(StoreNodes[i].MemNode, NewStore);
+
+    AddToWorklist(NewChain.getNode());
+    MadeChange = true;
+    StoreNodes.erase(StoreNodes.begin(),
+                     StoreNodes.begin() + BestNumStores);
+    NumConsecutiveStores -= BestNumStores;
+  }
+
+  return MadeChange;
+}
