   if (OptLevel == CodeGenOptLevel::None || !EnableStoreMerging)
     return false;
@@ -23916,12 +24061,15 @@ bool DAGCombiner::mergeConsecutiveStores(StoreSDNode *St) {
   if (ElementSizeBytes * 8 != (int64_t)MemVT.getSizeInBits())
     return false;
 
-  // Do not bother looking at stored values that are not constants, loads, or
-  // extracted vector elements.
+  // Classify the stored value. Constants, loads, extracted vector elements,
+  // and splat values (same value stored to consecutive addresses) are all
+  // candidates for merging.
   SDValue StoredVal = peekThroughBitcasts(St->getValue());
-  const StoreSource StoreSrc = getStoreSource(StoredVal);
+  StoreSource StoreSrc = getStoreSource(StoredVal);
+  // If the stored value is not a recognized constant/load/extract, check if
+  // it can participate in a splat merge.
   if (StoreSrc == StoreSource::Unknown)
-    return false;
+    StoreSrc = StoreSource::SplatValue;
 
   SmallVector<MemOpLink, 8> StoreNodes;
   // Find potential store merge candidates by searching through chain sub-DAG
@@ -23977,6 +24125,11 @@ bool DAGCombiner::mergeConsecutiveStores(StoreSDNode *St) {
                                          IsNonTemporalStore, IsNonTemporalLoad);
       break;
 
+    case StoreSource::SplatValue:
+      MadeChange |= tryStoreMergeOfSplatValues(StoreNodes, NumConsecutiveStores,
+                                               MemVT, RootNode, AllowVectors);
+      break;
+
     default:
       llvm_unreachable("Unhandled store source type");
     }
